# Open WebUI service configuration.
# Copy this file to open-webui/.env for local docker compose usage.
# On Railway, copy these values into the open-webui service variables.

PORT=8080
HOST=0.0.0.0

ENABLE_OPENAI_API=true
OPENAI_API_BASE_URLS=http://clinical-rag-agent:8000/v1
OPENAI_API_KEYS=local-dev-key

# Keep local Open WebUI embeddings disabled for Railway 1 GB deployments.
# Clinical RAG is handled by the clinical-rag-agent service.
RAG_EMBEDDING_MODEL=
RAG_RERANKING_MODEL=
AUXILIARY_EMBEDDING_MODEL=
BYPASS_EMBEDDING_AND_RETRIEVAL=true

WEBUI_SECRET_KEY=change-me

SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
CORS_ALLOW_ORIGIN=*
FORWARDED_ALLOW_IPS=*
