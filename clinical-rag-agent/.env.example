# Clinical RAG Agent service configuration.
# Copy this file to clinical-rag-agent/.env for local docker compose usage.
# On Railway, copy these values into the clinical-rag-agent service variables.

PORT=8000
CLINICAL_RAG_API_KEY=local-dev-key
CLINICAL_RAG_DATA_DIR=/app/data

# Default is deterministic local MVP behavior.
# Use openai_compatible to call an upstream model provider.
CLINICAL_RAG_LLM_PROVIDER=stub
CLINICAL_RAG_LLM_BASE_URL=
CLINICAL_RAG_LLM_API_KEY=
CLINICAL_RAG_LLM_MODEL=
