# Railway variables for the clinical-rag-agent service.
# Keep CLINICAL_RAG_API_KEY equal to OPENAI_API_KEYS in the Open WebUI service.

HOST=::
PORT=8000
CLINICAL_RAG_API_KEY=local-dev-key
CLINICAL_RAG_DATA_DIR=/app/data

CLINICAL_RAG_LLM_PROVIDER=openai_compatible
CLINICAL_RAG_LLM_BASE_URL=https://openrouter.ai/api/v1
CLINICAL_RAG_LLM_MODEL=google/gemma-4-31b-it:free
CLINICAL_RAG_LLM_API_KEY=<NEW_OPENROUTER_KEY>
