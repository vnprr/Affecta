# Railway variables for the Open WebUI service.
# OPENAI_API_KEYS must equal CLINICAL_RAG_API_KEY in the clinical-rag-agent service.

PORT=8080
HOST=0.0.0.0
FORWARDED_ALLOW_IPS=*

ENABLE_OPENAI_API=true
OPENAI_API_BASE_URLS=http://clinical-rag-agent.railway.internal:8000/v1
OPENAI_API_KEYS=local-dev-key

RAG_EMBEDDING_MODEL=
RAG_RERANKING_MODEL=
AUXILIARY_EMBEDDING_MODEL=
BYPASS_EMBEDDING_AND_RETRIEVAL=true

WEBUI_SECRET_KEY=<LONG_RANDOM_SECRET>

SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
CORS_ALLOW_ORIGIN=*
